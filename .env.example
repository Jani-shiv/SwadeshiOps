# ============================================
# SwadeshiOps Configuration
# ============================================

# Server
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
APP_SECRET=change-this-to-a-random-secret-key

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=swadeshiops
DB_PASSWORD=swadeshiops_dev
DB_NAME=swadeshiops
DB_SSLMODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-this-to-a-random-jwt-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Encryption (for secrets vault)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Docker
DOCKER_SOCKET=/var/run/docker.sock
RUNNER_MAX_WORKERS=2
RUNNER_TIMEOUT=600

# Logging
LOG_LEVEL=debug
LOG_FORMAT=console

# Notifications
TELEGRAM_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@swadeshiops.dev

# Frontend
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Observability
GRAFANA_ADMIN_PASSWORD=change-me-before-production

# Vite (for frontend build)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=/api
